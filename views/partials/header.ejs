<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - gcd</title>
  <!-- Favicon -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⭐</text></svg>">
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <!-- Stylesheets -->
  <link rel="stylesheet" href="/css/style.css">
  <% if (path && path.startsWith('/admin')) { %>
    <link rel="stylesheet" href="/css/admin.css">
  <% } %>
  <!-- Marked highlight style (optional, loaded dynamically if in blog detail) -->
  <% if (title !== 'Home' && title !== 'Blog' && title !== 'Projects' && title !== 'Admin Login' && title !== 'Dashboard') { %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
  <% } %>
</head>
<body>
  <!-- Modern Grid Background -->
  <div class="bg-grid"></div>

  <!-- Navbar -->
  <header class="navbar">
    <div class="container nav-container">
      <a href="/" class="nav-logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
          <polyline points="2 17 12 22 22 17"></polyline>
          <polyline points="2 12 12 17 22 12"></polyline>
        </svg>
        <span>gcd.</span>
      </a>
      
      <nav>
        <ul class="nav-links">
          <li><a href="/" class="nav-link">Home</a></li>
          <li><a href="/blog" class="nav-link">Blog</a></li>
          <li><a href="/projects" class="nav-link">Projects</a></li>
          <% if (user) { %>
            <li><a href="/admin" class="nav-link" style="color: var(--accent);">Dashboard</a></li>
          <% } %>
        </ul>
      </nav>

      <div class="nav-actions">
        <% if (!user) { %>
          <a href="/admin/login" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Login</a>
        <% } else { %>
          <a href="/admin" class="btn btn-primary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Admin</a>
        <% } %>
      </div>
    </div>
  </header>

  <main class="main-content container">
