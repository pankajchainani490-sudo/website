<%- include('../partials/header') %>

<div style="margin-bottom: 3rem;">
  <h1 style="font-size: 2.5rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 0.5rem;">Projects</h1>
  <p style="color: var(--text-secondary);">Here are some of the projects and tools deployed on my server and developed in my daily work.</p>
</div>

<div class="card-grid">
  <% if (projects && projects.length > 0) { %>
    <% projects.forEach(project => { %>
      <div class="card project-card">
        <div class="project-icon">
          <%= project.icon || '🚀' %>
        </div>
        <div class="project-info">
          <h3 class="project-title">
            <a href="<%= project.url %>" target="_blank" rel="noopener noreferrer">
              <%= project.name %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </a>
          </h3>
          <p class="project-desc"><%= project.description || 'No description available' %></p>
          <span class="project-category"><%= project.category || 'Project' %></span>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="card" style="grid-column: 1 / -1; text-align: center; color: var(--text-secondary); padding: 5rem 3rem;">
      <p style="font-size: 1.1rem; margin-bottom: 1.5rem;">No showcase projects have been added yet.</p>
      <a href="/admin" class="btn btn-primary">Add projects in Dashboard</a>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
