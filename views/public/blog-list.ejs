<%- include('../partials/header') %>

<div style="margin-bottom: 3rem;">
  <h1 style="font-size: 2.5rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 0.5rem;">My Blog</h1>
  <p style="color: var(--text-secondary);">Documenting development journey, reflections, and interesting practical cases.</p>
</div>

<div class="card-grid">
  <% if (posts && posts.length > 0) { %>
    <% posts.forEach(post => { %>
      <article class="card blog-card">
        <div class="blog-meta">
          <time><%= new Date(post.created_at).toLocaleDateString('en-US', {year: 'numeric', month: 'long', day: 'numeric'}) %></time>
          <% if (post.tags) { %>
            <span class="blog-tag"><%= post.tags.split(',')[0] %></span>
          <% } %>
        </div>
        <h3 class="blog-card-title">
          <a href="/blog/<%= post.slug %>"><%= post.title %></a>
        </h3>
        <p class="blog-card-summary"><%= post.summary || 'No summary available' %></p>
        <a href="/blog/<%= post.slug %>" class="btn btn-secondary" style="align-self: flex-start; padding: 0.4rem 0.8rem; font-size: 0.85rem;">Read More</a>
      </article>
    <% }) %>
  <% } else { %>
    <div class="card" style="grid-column: 1 / -1; text-align: center; color: var(--text-secondary); padding: 5rem 3rem;">
      <p style="font-size: 1.1rem; margin-bottom: 1.5rem;">It's empty here. No blog articles have been published yet.</p>
      <a href="/admin" class="btn btn-primary">Create one in Dashboard</a>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
